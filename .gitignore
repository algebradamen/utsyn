!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# database
/data/

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.sublime-project
.sublime-workspace
*.iml

# OS
